<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ajouter une dépense</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <main>
    <h1>Ajouter une dépense</h1>
    <a href="/">← Retour à la liste</a>

    <% if (errors.length > 0) { %>
      <div class="errors" role="alert">
        <ul>
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/add" novalidate>
      <div class="field">
        <label for="amount">Montant (€) <span aria-hidden="true">*</span></label>
        <input
          type="number"
          id="amount"
          name="amount"
          step="0.01"
          min="0.01"
          value="<%= values.amount || '' %>"
          required
          aria-required="true"
        >
      </div>

      <div class="field">
        <label for="category">Catégorie <span aria-hidden="true">*</span></label>
        <input
          type="text"
          id="category"
          name="category"
          value="<%= values.category || '' %>"
          required
          aria-required="true"
        >
      </div>

      <div class="field">
        <label for="date">Date <span aria-hidden="true">*</span></label>
        <input
          type="date"
          id="date"
          name="date"
          value="<%= values.date || '' %>"
          required
          aria-required="true"
        >
      </div>

      <div class="field">
        <label for="description">Description</label>
        <input
          type="text"
          id="description"
          name="description"
          value="<%= values.description || '' %>"
        >
      </div>

      <button type="submit" class="btn">Enregistrer</button>
    </form>
  </main>
</body>
</html>
