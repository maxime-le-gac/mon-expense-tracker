<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mes dépenses</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/nav', { activePage: 'list' }) %>
  <main>
    <h1>Mes dépenses</h1>

    <% if (expenses.length === 0) { %>
      <p class="empty">Aucune dépense enregistrée.</p>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th scope="col">Date</th>
            <th scope="col">Catégorie</th>
            <th scope="col">Montant (€)</th>
            <th scope="col">Description</th>
          </tr>
        </thead>
        <tbody>
          <% expenses.forEach(e => { %>
            <tr>
              <td><%= e.date %></td>
              <td><%= e.category %></td>
              <td class="amount"><%= e.amount.toFixed(2) %></td>
              <td><%= e.description || '' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
